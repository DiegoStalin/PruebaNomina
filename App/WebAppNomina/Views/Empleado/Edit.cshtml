@model WebAppNomina.Models.Empleado

@{
    ViewBag.Title = "Editar Empleado";
}

<div class="container" style="margin-top:20px;">
    <h2>@ViewBag.Title</h2>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        @* ¡VITAL! Sin esto el sistema no sabe a quién estás editando en SQL *@
        @Html.HiddenFor(model => model.emp_no)

        <div class="form-horizontal well">
            <h4>Modificando a: @Model.first_name @Model.last_name</h4>
            <hr />
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            @* 1. Cédula *@
            <div class="form-group">
                <label class="control-label col-md-2">Cédula (CI)</label>
                <div class="col-md-10">
                    @Html.EditorFor(model => model.ci, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.ci, "", new { @class = "text-danger" })
                </div>
            </div>

            @* 2. Nombre *@
            <div class="form-group">
                <label class="control-label col-md-2">Nombre</label>
                <div class="col-md-10">
                    @Html.EditorFor(model => model.first_name, new { htmlAttributes = new { @class = "form-control" } })
                </div>
            </div>

            @* 3. Apellido *@
            <div class="form-group">
                <label class="control-label col-md-2">Apellido</label>
                <div class="col-md-10">
                    @Html.EditorFor(model => model.last_name, new { htmlAttributes = new { @class = "form-control" } })
                </div>
            </div>

            @* 4. Correo *@
            <div class="form-group">
                <label class="control-label col-md-2">Correo</label>
                <div class="col-md-10">
                    @Html.EditorFor(model => model.correo, new { htmlAttributes = new { @class = "form-control" } })
                </div>
            </div>

            @* 5. Fecha de Nacimiento *@
            <div class="form-group">
                <label class="control-label col-md-2">Fecha Nac.</label>
                <div class="col-md-10">
                    @Html.TextBoxFor(model => model.birth_date, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                </div>
            </div>

            @* 6. Género *@
            <div class="form-group">
                <label class="control-label col-md-2">Género</label>
                <div class="col-md-10">
                    @Html.DropDownListFor(model => model.genero, new SelectList(new[] { "M", "F" }), "Seleccione", new { @class = "form-control" })
                </div>
            </div>

            @* 7. Contraseña (Para arreglar el NULL de los registros viejos) *@
            <div class="form-group">
                <label class="control-label col-md-2">Contraseña</label>
                <div class="col-md-10">
                    @Html.EditorFor(model => model.clave, new { htmlAttributes = new { @class = "form-control", placeholder = "Nueva contraseña" } })
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <input type="submit" value="Actualizar Datos" class="btn btn-primary" />
                    @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-default" })
                </div>
            </div>
        </div>
    }
</div>