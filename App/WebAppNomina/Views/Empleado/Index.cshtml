
@model IEnumerable<WebAppNomina.Models.Empleado>

@{
    ViewBag.Title = "Gestión de Empleados";
}

<style>
    .contenedor-personalizado {
        padding: 20px;
        background-color: #f9f9f9;
        border-radius: 8px;
    }

    .table thead {
        background-color: #343a40;
        color: white;
    }

    .btn-desactivar {
        background-color: #d9534f;
        color: white;
        border: none;
        padding: 5px 10px;
        border-radius: 4px;
    }
    /* Estilo para filas de inactivos */
    .inactivo {
        background-color: #f2dede !important;
        color: #a94442;
    }
</style>

<div class="contenedor-personalizado">
    <h2><i class="glyphicon glyphicon-user"></i> @ViewBag.Title</h2>
    <hr />

    <div class="well">
        @using (Html.BeginForm("Index", "Empleado", FormMethod.Get, new { @class = "form-inline" }))
        {
            <div class="form-group">
                @* Mantenemos el valor de la búsqueda en el input *@
                <input type="text" name="buscar" class="form-control" placeholder="Buscar por Nombre o CI..."
                       style="width: 300px;" value="@ViewBag.CurrentFilter" />
            </div>

            @* RF-10: Filtro por campo clave (Estado Activo/Inactivo) *@
            <div class="form-group" style="margin-left: 15px;">
                <label>Ver Inactivos:</label>
                <input type="checkbox" name="verInactivos" value="true" @(ViewBag.MostrandoInactivos == true ? "checked" : "") onchange="this.form.submit()" />
            </div>

            <button type="submit" class="btn btn-primary" style="margin-left: 10px;">
                <i class="glyphicon glyphicon-search"></i> Consultar
            </button>

            <a href="@Url.Action("Index")" class="btn btn-default">Limpiar</a>
        }
    </div>

    <p>
        @Html.ActionLink("Registrar Nuevo Empleado", "Create", null, new { @class = "btn btn-success" })
    </p>

    <table class="table table-hover table-bordered">
        <thead>
            <tr>
                <th>CI</th>
                <th>Nombre Completo</th>
                <th>Fecha Ingreso</th>
                <th>Correo</th>
                <th>Estado</th> @* Nueva columna para claridad *@
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.activo ? "" : "inactivo")">
                    <td>@item.ci</td>
                    <td>@item.first_name @item.last_name</td>
                    <td>@item.hire_date.ToShortDateString()</td>
                    <td>@item.correo</td>
                    <td>
                        @if (item.activo)
                        {
                            <span class="label label-success">Activo</span>
                        }
                        else
                        {
                            <span class="label label-danger">Inactivo</span>
                        }
                    </td>
                    <td>
                        @Html.ActionLink("Editar", "Edit", new { id = item.emp_no }, new { @class = "btn btn-info btn-xs" })

                        @if (item.activo)
                        {
                            <span>|</span>
                            using (Html.BeginForm("Delete", "Empleado", new { id = item.emp_no }, FormMethod.Post, new { style = "display:inline;" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-desactivar btn-xs" onclick="return confirm('¿Está seguro de desactivar este registro?');">
                                    <i class="glyphicon glyphicon-off"></i> Desactivar
                                </button>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>



    <hr /> <div class="text-center">
        <p>Página @ViewBag.PaginaActual de @ViewBag.TotalPaginas</p>
        <ul class="pagination">
            @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
            {
                <li class="@(i == ViewBag.PaginaActual ? "active" : "")" style="display:inline; margin-right:5px;">
                    @Html.ActionLink(i.ToString(), "Index", new { pagina = i, buscar = ViewBag.CurrentFilter, verInactivos = ViewBag.MostrandoInactivos }, new { @class = "btn btn-default" })
                </li>
            }
        </ul>
    </div>
</div>