
@model IEnumerable<WebAppNomina.Models.Departamento>

<div class="container" style="margin-top:20px;">
    <h2>Gestión de Departamentos</h2>
    <p>
        @Html.ActionLink("Nuevo Departamento", "Create", null, new { @class = "btn btn-success" })
    </p>
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre del Departamento</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.dept_no</td>
                    <td>@item.dept_name</td>
                    <td>
                        @Html.ActionLink("Editar", "Edit", new { id = item.dept_no }, new { @class = "btn btn-info btn-xs" })

                        @using (Html.BeginForm("Delete", "Departamento", new { id = item.dept_no }, FormMethod.Post, new { style = "display:inline;" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="submit" value="Desactivar" class="btn btn-danger btn-xs" onclick="return confirm('¿Seguro que desea desactivar este departamento?');" />
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>