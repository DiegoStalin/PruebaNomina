@model IEnumerable<WebAppNomina.Models.LogAuditoriaSalario>

@{
    ViewBag.Title = "Auditoría de Cambios Salariales";
}

<div class="container">
    <div class="row">
        <div class="col-md-12">
            <h2 class="text-primary">Auditoría de Salarios (RF-08)</h2>
            <p class="text-muted">Historial completo de altas y cambios registrados por el sistema.</p>
            <hr />
        </div>
    </div>

    @* --- BLOQUE DE FILTRO POR FECHAS (RF-09b) --- *@
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            @using (Html.BeginForm("Auditoria", "Salario", FormMethod.Get, new { @class = "row g-3 align-items-end" }))
            {
                <div class="col-md-4">
                    <label class="form-label fw-bold">Desde:</label>
                    <input type="date" name="inicio" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Hasta:</label>
                    <input type="date" name="fin" class="form-control" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="glyphicon glyphicon-search"></i> Filtrar Rango
                    </button>
                </div>
            }
        </div>
    </div>

    @* --- TABLA DE DATOS CON EXPORTACIÓN --- *@
    <div class="table-responsive mt-4">
        <table id="tablaAuditoria" class="table table-striped table-bordered table-hover">
            <thead class="bg-primary text-white">
                <tr>
                    <th>Fecha y Hora</th>
                    <th>Usuario Responsable</th>
                    <th>Empleado</th>
                    <th>Detalle del Movimiento</th>
                    <th>Monto Registrado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.fechaActualizacion.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>
                            <small class="text-secondary">@item.usuario</small>
                        </td>
                        <td>
                            @(item.Empleado != null ? item.Empleado.first_name : "ID: " + item.emp_no)
                        </td>
                        <td>
                            <span class="badge bg-info text-dark">@item.DetalleCambio</span>
                        </td>
                        <td class="text-end fw-bold">
                            @item.salario.ToString("C")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-4 mb-5">
        @Html.ActionLink("Volver al Historial de Salarios", "Index", null, new { @class = "btn btn-secondary" })
    </div>
</div>

@* --- SCRIPTS PARA EXPORTAR A PDF/EXCEL (RF-09) --- *@
@section scripts {
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/v/bs5/jszip-2.5.0/dt-1.11.3/b-2.0.1/b-html5-2.0.1/b-print-2.0.1/datatables.min.css" />

    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.36/pdfmake.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.36/vfs_fonts.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/v/bs5/jszip-2.5.0/dt-1.11.3/b-2.0.1/b-html5-2.0.1/b-print-2.0.1/datatables.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#tablaAuditoria').DataTable({
                dom: 'Bfrtip', // Define la posición de los botones
                buttons: [
                    {
                        extend: 'excelHtml5',
                        text: 'Exportar a Excel',
                        className: 'btn btn-success btn-sm',
                        title: 'Reporte_Cambios_Salariales'
                    },
                    {
                        extend: 'pdfHtml5',
                        text: 'Exportar a PDF',
                        className: 'btn btn-danger btn-sm',
                        title: 'Reporte_Cambios_Salariales'
                    },
                    {
                        extend: 'print',
                        text: 'Imprimir',
                        className: 'btn btn-info btn-sm'
                    }
                ],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.10.25/i18n/Spanish.json"
                },
                order: [[0, "desc"]] // Ordenar por fecha por defecto
            });
        });
    </script>
}