@model IEnumerable<WebAppNomina.Models.Salario>

<div class="container" style="margin-top:20px;">
    <div class="row">
        <div class="col-md-8">
            <h2 class="text-primary"><i class="glyphicon glyphicon-list-alt"></i> Historial de Salarios</h2>
        </div>
        <div class="col-md-4 text-right">
            @Html.ActionLink(" Registrar Nuevo Salario", "Create", null, new { @class = "btn btn-success" })
        </div>
    </div>

    @* --- BOTONES DE REPORTES RF-09 --- *@
    <div class="row" style="margin-top:15px; margin-bottom:15px;">
        <div class="col-md-12">
            <div class="btn-group">
                <a href="@Url.Action("Auditoria", "Salario")" class="btn btn-info">Auditoría (RF-08)</a>
                <a href="@Url.Action("ReporteNominaDepto", "Salario")" class="btn btn-warning">Nómina por Depto</a>
                <a href="@Url.Action("EstructuraOrg", "Salario")" class="btn btn-dark" style="background:#333; color:white;">Estructura Org.</a>
            </div>
        </div>
    </div>

    @* --- RF-10: FORMULARIO DE BÚSQUEDA Y FILTROS --- *@
    <div class="well">
        @using (Html.BeginForm("Index", "Salario", FormMethod.Get, new { @class = "form-horizontal" }))
        {
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group" style="margin-left:0; margin-right:0;">
                        <label>Buscar Empleado:</label>
                        <input type="text" name="busqueda" class="form-control" placeholder="Nombre o apellido..." value="@Request.QueryString["busqueda"]" />
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-group" style="margin-left:0; margin-right:0;">
                        <label>Departamento:</label>
                        @Html.DropDownList("dept_no", (SelectList)ViewBag.dept_no, "Todos los Departamentos", new { @class = "form-control" })
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-group" style="margin-left:0; margin-right:0;">
                        <label>Vigencia a la fecha:</label>
                        <input type="date" name="fechaVigencia" class="form-control" value="@Request.QueryString["fechaVigencia"]" />
                    </div>
                </div>
            </div>

            <div class="row" style="margin-top:10px;">
                <div class="col-md-12 text-center">
                    <button type="submit" class="btn btn-primary">
                        <i class="glyphicon glyphicon-filter"></i> Aplicar Filtros
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-default">
                        <i class="glyphicon glyphicon-erase"></i> Limpiar Filtros
                    </a>
                </div>
            </div>
        }
    </div>

    @* --- TABLA DE RESULTADOS --- *@
    <table class="table table-striped table-bordered">
        <thead class="bg-primary" style="color:white;">
            <tr>
                <th>Empleado</th>
                <th>Monto Salarial</th>
                <th>Fecha Inicio</th>
                <th>Fecha Fin</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Empleado.first_name @item.Empleado.last_name</td>
                    <td>
                        <strong>@item.salary.ToString("C")</strong>
                    </td>
                    <td>@item.from_date.ToShortDateString()</td>
                    <td>@(item.to_date.HasValue ? item.to_date.Value.ToShortDateString() : "Indefinido")</td>
                    <td>
                        @if (!item.to_date.HasValue || item.to_date >= DateTime.Now)
                        {<span class="label label-success">Activo</span> }
                        else
                        { <span class="label label-default">Histórico</span>}
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-danger">No se encontraron resultados con los filtros aplicados.</td>
                </tr>
            }
        </tbody>
    </table>
</div>