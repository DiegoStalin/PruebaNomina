@model IEnumerable<WebAppNomina.Models.Departamento>

<div class="container" style="margin-top:20px;">
    <h2 class="text-primary"><i class="glyphicon glyphicon-list"></i> Nómina por Departamento</h2>
    <hr />
    <table class="table table-bordered table-striped">
        <thead class="bg-warning">
            <tr>
                <th>Código Depto</th>
                <th>Nombre del Departamento</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var depto in Model)
            {
                <tr>
                    <td>@depto.dept_no</td>
                    <td>@depto.dept_name</td>
                    <td><span class="label label-success">Activo</span></td>
                </tr>
            }
        </tbody>
    </table>
    @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-default" })
</div>
