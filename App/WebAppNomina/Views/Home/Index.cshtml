@{
    ViewBag.Title = "Panel Principal - Sistema de Nómina";
}

<div class="jumbotron shadow-sm" style="background-color: #f8f9fa; padding: 2rem; border-radius: 15px; margin-top: 20px;">
    <h1 class="display-4 text-primary">Bienvenido al Sistema de Nómina</h1>

    @if (Session["UsuarioNombre"] != null)
    {
        @* Eliminado (RF-07, RF-08, RF-11) para mayor limpieza visual *@
        <p class="lead">Hola <strong>@Session["UsuarioNombre"]</strong>, bienvenido al panel de gestión de la empresa.</p>
    }
    else
    {
        <p class="lead">Por favor, inicie sesión para acceder a las funciones de administración.</p>
    }

    <hr class="my-4">

    <div class="row text-center">
        <div class="col-md-4">
            <div class="card border-primary mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-muted"><i class="glyphicon glyphicon-user"></i> Empleados Activos</h5>
                    <p class="h2">@ViewBag.TotalEmpleados</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-info mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-muted"><i class="glyphicon glyphicon-refresh"></i> Cambios Hoy</h5>
                    <p class="h2">@ViewBag.UltimosCambios</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            @if (User.Identity.IsAuthenticated)
            {
                <a href="@Url.Action("Index", "Salario")" class="btn btn-primary btn-block p-3 shadow">
                    <i class="glyphicon glyphicon-usd"></i> Gestionar Salarios
                </a>
            }
            else
            {
                <a href="@Url.Action("Autenticar", "Home")" class="btn btn-success btn-block p-3 shadow">
                    <i class="glyphicon glyphicon-log-in"></i> Iniciar Sesión
                </a>
            }
        </div>
    </div>
</div>

@if (User.Identity.IsAuthenticated)
{
    <div class="row mt-4">
        <div class="col-md-4">
            @* Texto limpio sin (RF-12) *@
            <h3><i class="glyphicon glyphicon-briefcase"></i> Recursos Humanos</h3>
            <p>Gestión integral de empleados, cargos, títulos y asignación de departamentos.</p>
            <p><a class="btn btn-outline-secondary" href="@Url.Action("Index", "Empleado")">Ver Empleados &raquo;</a></p>
        </div>
        <div class="col-md-4">
            @* Texto limpio sin (RF-09) *@
            <h3><i class="glyphicon glyphicon-list-alt"></i> Módulo de Reportes</h3>
            <p>Generación de nómina vigente y exportación de auditorías a formatos Excel y PDF.</p>
            <p><a class="btn btn-outline-secondary" href="@Url.Action("Auditoria", "Salario")">Ver Auditoría &raquo;</a></p>
        </div>
        <div class="col-md-4">
            <h3><i class="glyphicon glyphicon-lock"></i> Seguridad</h3>
            <p>Control de acceso, gestión de sesiones activas y protección de datos críticos.</p>
            <p><a class="btn btn-outline-danger" href="@Url.Action("Salir", "Home")">Cerrar Sesión &raquo;</a></p>
        </div>
    </div>
}