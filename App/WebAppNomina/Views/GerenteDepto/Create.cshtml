
@model WebAppNomina.Models.GerenteDepto

<div class="container" style="margin-top:20px;">
    <h2>Registrar Nombramiento de Gerente</h2>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-horizontal panel panel-default" style="padding:20px;">
            <h4>Información del Cargo</h4>
            <hr />
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            <div class="form-group">
                <label class="control-label col-md-2">Seleccionar Empleado:</label>
                <div class="col-md-10">
                    @Html.DropDownList("emp_no", null, "-- Seleccione al nuevo Jefe --", htmlAttributes: new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.emp_no, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                <label class="control-label col-md-2">Departamento:</label>
                <div class="col-md-10">
                    @Html.DropDownList("dept_no", null, "-- Seleccione Departamento --", htmlAttributes: new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.dept_no, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                <label class="control-label col-md-2">Fecha Inicio:</label>
                <div class="col-md-4">
                    @Html.EditorFor(model => model.from_date, new { htmlAttributes = new { @class = "form-control", type = "date" } })
                    @Html.ValidationMessageFor(model => model.from_date, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                <label class="control-label col-md-2">Fecha Fin:</label>
                <div class="col-md-4">
                    @Html.EditorFor(model => model.to_date, new { htmlAttributes = new { @class = "form-control", type = "date" } })
                    @Html.ValidationMessageFor(model => model.to_date, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <button type="submit" class="btn btn-primary">
                        <i class="glyphicon glyphicon-save"></i> Guardar Nombramiento
                    </button>
                    @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-default" })
                </div>
            </div>
        </div>
    }
</div>