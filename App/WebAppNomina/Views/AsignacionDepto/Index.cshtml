@model IEnumerable<WebAppNomina.Models.AsignacionDepto>

<div class="container" style="margin-top:20px;">
    <h2>Historial de Asignaciones a Departamentos</h2>
    <p>
        @Html.ActionLink("Asignar Nuevo Departamento", "Create", null, new { @class = "btn btn-success" })
    </p>

    <table class="table table-striped table-bordered">
        <thead>
            <tr class="bg-primary" style="color:white;">
                <th>Empleado</th>
                <th>Departamento</th>
                <th>Fecha Inicio (Desde)</th>
                <th>Fecha Fin (Hasta)</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Empleado.first_name @item.Empleado.last_name</td> @* Usamos la propiedad de navegación *@
                    <td>@item.Departamento.dept_name</td>
                    <td>@item.from_date.ToShortDateString()</td>
                    <td>@item.to_date.ToShortDateString()</td>
                    <td>
                        @using (Html.BeginForm("Delete", "AsignacionDepto", new { id = item.id }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <input type="submit" value="Eliminar" class="btn btn-danger btn-xs" onclick="return confirm('¿Eliminar esta asignación?');" />
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
