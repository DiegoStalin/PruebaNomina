<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - APP Web Nómina</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <style>
        /* Estilo simple para separar el contenido del nav */
        body {
            padding-top: 70px;
        }
    </style>
</head>
<body>
    <div class="contenedor-login-style">
        <div class="tarjeta-login-style">

    <nav class="navbar navbar-expand-sm navbar-dark bg-dark fixed-top">
        <div class="container">
            @Html.ActionLink("APP Nómina", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="navbar-collapse collapse justify-content-between">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        @Html.ActionLink("Inicio", "Index", "Home", null, new { @class = "nav-link" })
                    </li>

                    @* RF-12: Solo mostrar gestión a usuarios logueados *@
                    @if (Request.IsAuthenticated)
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Empleados", "Index", "Empleado", null, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Salarios", "Index", "Salario", null, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Auditoría", "Auditoria", "Salario", null, new { @class = "nav-link" })
                        </li>
                    }
                </ul>

                <ul class="navbar-nav">
                    @if (Request.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-info">
                                <i class="glyphicon glyphicon-user"></i> @(Session["UsuarioNombre"] ?? User.Identity.Name)
                            </span>
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Cerrar Sesión", "Salir", "Home", null, new { @class = "nav-link btn btn-outline-danger btn-sm ml-2" })
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Iniciar Sesión", "Autenticar", "Home", null, new { @class = "nav-link" })
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - APP Web Nómina - Gestión Profesional</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

</body>
</html>