
@model IEnumerable<WebAppNomina.Models.Titulo>

<div class="container" style="margin-top:20px;">
    <h2 class="text-primary"><i class="glyphicon glyphicon-briefcase"></i> Historial de Títulos / Cargos</h2>
    <p>
        @Html.ActionLink("Asignar Nuevo Cargo", "Create", null, new { @class = "btn btn-success" })
    </p>

    <table class="table table-striped table-bordered">
        <thead>
            <tr class="success">
                <th>Empleado</th>
                <th>Título / Cargo</th>
                <th>Fecha Inicio</th>
                <th>Fecha Fin</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Empleado.first_name @item.Empleado.last_name</td>
                    <td><strong>@item.title</strong></td>
                    <td>@item.from_date.ToShortDateString()</td>
                    <td>@(item.to_date.HasValue ? item.to_date.Value.ToShortDateString() : "Actual")</td>
                    <td>
                        @using (Html.BeginForm("Delete", "Titulo", new { id = item.id }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Eliminar este registro de cargo?');">
                                <i class="glyphicon glyphicon-trash"></i>
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>